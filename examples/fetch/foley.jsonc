// The foley fetch look: the film chip as logo (foley.ans, the brand's
// single source), the modules that matter. `Terminal: foley` is not
// styling — foley IS the terminal the demo runs in;
// fastfetch simply reports it.
{
  "logo": {
    "type": "file-raw",
    "source": "../../assets/logo/foley.ans",
    "padding": { "top": 2, "right": 4 }
  },
  "modules": ["break", "os", "shell", "terminal", "cpu", "gpu", "memory", "break", "colors"]
}
