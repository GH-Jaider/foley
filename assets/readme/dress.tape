# One take, two dresses: the look is a flag (or a cue in the tape) —
# the script never changes. Recorded twice by scripts/examples.sh.
Output dress.gif
Require bash
Set Shell bash
Set Width 640
Set Height 200
Set FontSize 15
Set TypingSpeed 45ms
Set WaitTimeout 20s
# foley: studio
Sleep 400ms
Type "echo one take, many dresses"
Enter
Wait
Sleep 1400ms
